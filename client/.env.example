# Lambda Function URL base (no trailing slash)
# Dev: Vite proxies /api and /health to this URL
# Prod: the built app calls this URL directly
#
# Lambda must be deployed with:
#   Handler: handler (or streamHandler)
#   Function URL invoke mode: RESPONSE_STREAM
VITE_API_BASE_URL=https://xxxxxxxxxx.lambda-url.us-east-1.on.aws
